# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/

# =========================
# Environments
# =========================
.env
.env.*
.venv/
venv/
env/
*.key
secrets.yaml
.env.local

# =========================
# Jupyter / IDE / OS
# =========================
.ipynb_checkpoints/
*.ipynb
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# =========================
# Heavy data: raw / processed corpus
# Keep folder structure using .gitkeep only
# =========================
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

# =========================
# Heavy indexes / embeddings
# =========================
data/embeddings/*
!data/embeddings/.gitkeep

*.faiss
*.index
*.pkl
*.bin
*.npy
*.npz
*.parquet

# =========================
# Benchmark images
# Do not push real screenshots unless intentionally small/public
# =========================
data/benchmark/images/*
!data/benchmark/images/.gitkeep

# Keep benchmark JSON files
!data/benchmark/benchmark.json
!data/benchmark/benchmark_template.json
!data/benchmark/README.md

# =========================
# Results and logs
# Keep final small tables/json if needed, ignore logs
# =========================
results/logs/*
!results/logs/.gitkeep

*.log
*.out
*.err
slurm-*.out

# Optional: ignore very large result artifacts
results/*.png
results/*.jpg
results/*.jpeg
results/*.pdf

# Keep small report-ready result JSON/Markdown tables
!results/*.json
!results/tables/
!results/tables/*.md

# =========================
# Model/cache files
# =========================
models/
checkpoints/
.cache/
huggingface/
wandb/

# =========================
# SLURM temporary files
# =========================
core.*
